# Neogogy Readiness Index - runtime environment
# Copy to .env.production on the server (or set in the systemd unit).

NODE_ENV=production
PORT=3000

# AWS region for DynamoDB (and SES later)
AWS_REGION=ap-southeast-1

# Credentials for DynamoDB access. On EC2 you may instead attach an instance
# role; if you do, omit these two lines.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB tables. If unset, the app falls back to local JSON files in ./data.
LEADS_TABLE=neogogy-leads
EVENTS_TABLE=neogogy-events

# Shared token that protects GET /api/stats (?token=... or x-stats-token header)
STATS_TOKEN=change-me

# DynamoDB table of admin users (username + scrypt-hashed password).
USERS_TABLE=neogogy-users

# Break-glass password for /admin if the users table is empty/unreachable.
ADMIN_PASSWORD=change-me

# Email (Amazon SES). Leave EMAIL_ENABLED=false until the IAM user has
# ses:SendEmail, the sending domain is verified, and the account is out of the
# SES sandbox. While false, results show on screen and the PDF downloads; no
# email is sent.
EMAIL_ENABLED=false
EMAIL_FROM=report@neogogy.ai
